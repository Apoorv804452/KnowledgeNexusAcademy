            overflow-x: auto;
            padding: 12px 16px;
        }
        .math-block .katex-display > .katex {
            display: inline-block;
            white-space: nowrap;
        }
        .math-block .katex-display > .katex > .katex-html {
            display: inline-block;
        }
        /* Ensure inline math renders well */
        .math-inline .katex {
            font-size: 1.05em;
        }
        /* Fix for display math in paragraphs */
        .main-content p .katex-display {
            display: inline-block;
            margin: 0;
        }
    </style>
</head>
